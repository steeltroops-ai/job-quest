generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model JobApplication {
  id          Int      @id @default(autoincrement())
  company     String
  role        String
  location    String?
  region      String   @default("Any")
  type        String   @default("Full-time")
  status      String   @default("Applied")
  round       String?  
  date        String
  deadline    String?
  followUp    String?
  link        String?
  salary      String?
  contact     String?
  notes       String?
  priority    String   @default("Medium")
  resume      String?
  coverLetter String?
  source      String?
  tags        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Goal {
  id     Int    @id @default(autoincrement())
  count  Int    @default(5)
  target String @default("Weekly Applications")
}

model GoalTask {
  id        Int      @id @default(autoincrement())
  text      String
  note      String?
  done      Boolean  @default(false)
  category  String   @default("Execution") // e.g., "Execution", "Audit"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
